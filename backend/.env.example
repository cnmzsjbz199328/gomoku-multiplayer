# Railway 环境变量配置
# 在 Railway 控制台设置这些变量

# 服务器配置
PORT=3000
NODE_ENV=production

# JWT 密钥（生产环境请使用强随机密钥）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your-production-jwt-secret-change-this

# CORS 配置（前端部署后的域名）
# 例如：https://gomoku.yourdomain.com
CORS_ORIGIN=*

# Redis 配置（可选，如果需要持久化）
# REDIS_HOST=redis.railway.internal
# REDIS_PORT=6379
